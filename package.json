{
  "name": "clipboard-manager",
  "version": "1.0.0",
  "description": "Windows Win+V style clipboard manager for macOS",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --enable-logging",
    "build": "electron-builder --mac dmg",
    "build:universal": "electron-builder --mac dmg --arm64 --x64",
    "build:dir": "electron-builder --mac dir",
    "setup-startup": "node scripts/setup-startup.js",
    "remove-startup": "node scripts/setup-startup.js remove"
  },
  "keywords": [
    "clipboard",
    "macos",
    "history"
  ],
  "author": "",
  "license": "MIT",
  "build": {
    "appId": "com.clipboard.manager",
    "productName": "Clipboard",
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        "dmg"
      ]
    },
    "dmg": {
      "title": "Clipboard ${version}"
    },
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "styles.css",
      "renderer.js"
    ],
    "directories": {
      "output": "dist"
    },
    "publish": null
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.13.3"
  }
}
